@model BizzyQCU.Models.EnterpriseDetailViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.StoreName + " - BizzyQCU";
    ViewBag.BodyClass = "view-enterprise-bg";
}

<div class="enterprise-page">

    <div class="enterprise-floating-card">

        @* ── Enterprise Header ── *@
        <div class="enterprise-header">
            <div class="left-section">
                <div class="enterprise-picture">
                    @if (Model.StoreLogo != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.StoreLogo)"
                             alt="@Model.StoreName" />
                    }
                    else
                    {
                        <img src="~/Content/Images/test-img-profile.jpg" alt="@Model.StoreName" />
                    }
                </div>
                <div class="ent-info">
                    <h2>@Model.StoreName</h2>
                    <span class="status-online">Online</span>
                </div>
            </div>
        </div>

        @* ── Products ── *@
        <div class="ent-product-section">
            <h2>PRODUCTS</h2>

            @if (Model.Products == null || Model.Products.Count == 0)
            {
                <p style="color:#999; text-align:center; padding:30px 0;">
                    No products available yet.
                </p>
            }
            else
            {
                <div class="ent-product-grid">
                    @foreach (var product in Model.Products)
                    {
                        string productUrl = Url.Action("ProductChild", "ProductChild", new { id = product.ProductId });

                        <div class="ent-product-card"
                             onclick="window.location.href = '@productUrl'"
                             style="cursor:pointer;">

                            <div class="product-img-container">
                                @if (product.ProductImage != null)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(product.ProductImage)"
                                         alt="@product.ProductName" />
                                }
                                else
                                {
                                    <img src="~/Content/Images/test-img1.jpg" alt="@product.ProductName" />
                                }
                            </div>

                            <div class="ent-product-info">
                                <span class="ent-product-name">@product.ProductName</span>
                                <span class="ent-product-price">&#8369;@product.Price.ToString("0.00")</span>
                            </div>

                        </div>
                    }
                </div>
            }

        </div>

    </div>

</div>

@* ── Ad Modal ── *@
<div id="ent-ad-modal" class="ad-modal">
    <div class="ad-modal-content">
        <span class="close-btn">&times;</span>
        <img src="@Url.Content(ViewBag.AdImageUrl ?? "~/Content/Images/ad-sample.png")" alt="enterprise-ad" />
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/Enterprise-Ad-Modal.js"></script>
}
