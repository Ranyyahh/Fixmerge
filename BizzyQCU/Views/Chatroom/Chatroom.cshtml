@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chatroom";
    int orderId = ViewBag.OrderId != null ? Convert.ToInt32(ViewBag.OrderId) : 0;
    bool chatOpen = ViewBag.ChatOpen == null || Convert.ToBoolean(ViewBag.ChatOpen);
}

<div class="product-page-container chatroom-page-container">
    <div class="chatroom-shell">
        <section class="chatroom-thread">
            <div class="chatroom-thread-header">
                <div class="chatroom-thread-title">@ViewBag.StoreName</div>
                <span class="chatroom-thread-status">Order #QCU-@orderId</span>
            </div>

            <div class="chatroom-messages" id="chatMessages">
            </div>

            <div class="chatroom-composer">
                <input type="text" id="msgInput" class="chatroom-input" placeholder="Type your message..." @(chatOpen ? "" : "disabled") />
                <button type="button" id="sendBtn" class="enterprise-btn chatroom-send-btn" @(chatOpen ? "" : "disabled")>Send</button>
            </div>
        </section>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    var myUserId = @(Session["UserId"] ?? 0);
    var orderId = @orderId;
    var chatOpen = @chatOpen.ToString().ToLowerInvariant();
    var lastRendered = '';

    function htmlEncode(value) {
        return $('<div/>').text(value || '').html();
    }

    function fetchChat() {
        if (!orderId) return;

        $.get('/Chatroom/GetMessages', { orderId: orderId }, function (data) {
            if (!data || data.success === false) {
                $('#chatMessages').html('<div class="chat-bubble incoming">' + htmlEncode((data && data.message) || 'Unable to load messages.') + '</div>');
                return;
            }

            var messages = data.messages || [];
            var html = '';
            messages.forEach(function (m) {
                var type = m.messageType || ((m.senderId == myUserId) ? 'outgoing' : 'incoming');
                html += '<div class="chat-bubble ' + htmlEncode(type) + '">';
                html += '<div>' + htmlEncode(m.text) + '</div>';
                html += '<small>' + htmlEncode(m.sentAt) + '</small>';
                html += '</div>';
            });

            if (!html) {
                html = '<div class="chat-bubble incoming">No messages yet.</div>';
            }

            if (html !== lastRendered) {
                $('#chatMessages').html(html);
                lastRendered = html;
                var objDiv = document.getElementById("chatMessages");
                objDiv.scrollTop = objDiv.scrollHeight;
            }
        });
    }

    function sendMessage() {
        if (!chatOpen || !orderId) return;

        var msg = $('#msgInput').val().trim();
        if (!msg) return;

        $('#sendBtn').prop('disabled', true);
        $.post('/Chatroom/SendMessage', { orderId: orderId, message: msg }, function (data) {
            if (data && data.success) {
                $('#msgInput').val('');
                fetchChat();
            } else {
                alert((data && data.message) || 'Message not sent.');
            }
        }).always(function () {
            $('#sendBtn').prop('disabled', false);
        });
    }

    $('#sendBtn').click(sendMessage);

    $('#msgInput').on('keydown', function (event) {
        if (event.key === 'Enter') {
            event.preventDefault();
            sendMessage();
        }
    });

    if (!chatOpen) {
        $('#chatMessages').html('<div class="chat-bubble incoming">This chat is already closed for this order.</div>');
    }

    setInterval(fetchChat, 3000);
    fetchChat();
</script>
