<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BizzyQCU</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/Content/layout.css">
    <link rel="stylesheet" href="~/Content/home_about_product_ent.css">
    <link rel="stylesheet" href="~/Content/Chatroom.css">
    <link rel="stylesheet" href="~/Content/MobileNavbar.css">
    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var sessionRole = Session["Role"] == null ? string.Empty : Session["Role"].ToString();

        // URL para sa account base sa role - dapat sa PROFILE
        var accountUrl = "";
        if (sessionRole == "enterprise")
        {
            accountUrl = Url.Action("EnterpriseProfile", "Profile");
        }
        else if (sessionRole == "student")
        {
            accountUrl = Url.Action("UserProfile", "Profile");
        }
        else if (sessionRole == "admin")
        {
            accountUrl = Url.Action("AdminProfile", "Admin");
        }
        else
        {
            accountUrl = Url.Action("Login", "Home");
        }

        // Home URL base sa role
        var homeUrl = "";
        if (sessionRole == "enterprise")
        {
            homeUrl = Url.Action("EnterpriseDashboard", "EnterpriseDashboard");
        }
        else if (sessionRole == "student")
        {
            homeUrl = Url.Action("ProductList", "ProductList");
        }
        else if (sessionRole == "admin")
        {
            homeUrl = Url.Action("AdminDashboard", "AdminDashboard");
        }
        else
        {
            homeUrl = Url.Action("Homepage", "Home");
        }
    }

    <div class="navbar">

        <a href="javascript:history.back()" class="mobile-back-btn">
            <img src="~/Content/Images/back-btn.png" class="back-icon" alt="Back" />
        </a>

        <div class="logo">
            <a href="@homeUrl"><img src="~/Images/Logo.png" alt="logo" /></a>
        </div>

        <div class="divider"></div>

        <div class="nav-links" id="mainNav">
            @if (sessionRole == "enterprise")
            {
                <a href="@Url.Action("EnterpriseDashboard", "EnterpriseDashboard")">DASHBOARD</a>
                <a href="@Url.Action("AddProduct", "AddProduct")">ADD PRODUCT</a>
                <a href="@Url.Action("ManageOrders", "ManageOrders")">MANAGE ORDERS</a>
                <a href="@Url.Action("EditStore", "EditStore")">EDIT STORE</a>
            }
            else if (sessionRole == "student")
            {
                <a href="@Url.Action("ProductList", "ProductList")">PRODUCTS</a>
                <a href="@Url.Action("ViewEnterprise", "ViewEnterprise")">ENTERPRISES</a>
                <a href="@Url.Action("Tracking", "Home")">TRACK ORDER</a>
                <a href="@Url.Action("About", "Home")">ABOUT US</a>
            }
            else if (sessionRole == "admin")
            {
                <a href="@Url.Action("AdminDashboard", "AdminDashboard")">DASHBOARD</a>
                <a href="@Url.Action("PendingApprovals", "Admin")">PENDING APPROVALS</a>
                <a href="@Url.Action("ManageUsers", "Admin")">MANAGE USERS</a>
            }
            else
            {
                <a href="@Url.Action("Homepage", "Home")">HOME</a>
                <a href="@Url.Action("ProductList", "ProductList")">PRODUCTS</a>
                <a href="@Url.Action("ViewEnterprise", "ViewEnterprise")">ENTERPRISES</a>
                <a href="@Url.Action("About", "Home")">ABOUT US</a>
            }

            <a href="@accountUrl" class="account-mobile">
                ACCOUNT
            </a>
        </div>

        <div class="right-icons">
            @if (sessionRole != "enterprise" && sessionRole != "admin")
            {
                <div class="cart-icon">
                    <a href="#"><img src="~/Images/cart-icon.png" alt="Cart" onclick="window.location.href = '@Url.Action("Tracking", "Home")'" /></a>
                </div>
            }
            <div class="account-icon account-desktop">
                <a href="@accountUrl">
                    <img src="~/Images/account-icon.png" alt="Account" />
                </a>
            </div>

            <button class="hamburger" id="hamburgerBtn">
                ☰
            </button>
        </div>

    </div>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align:center; margin-top:2rem; padding:1rem; color:#6c757d;">
        &copy; 2025 BizzyQCU - One Enterprise at a Time
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <!-- FOR HAMBURGER TOGGLE -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btn = document.getElementById("hamburgerBtn");
            const nav = document.getElementById("mainNav");
            const body = document.body;

            if (btn && nav) {
                btn.addEventListener("click", function () {
                    nav.classList.toggle("open");
                    body.classList.toggle("menu-open", nav.classList.contains("open"));
                });

                nav.querySelectorAll("a").forEach(function (link) {
                    link.addEventListener("click", function () {
                        nav.classList.remove("open");
                        body.classList.remove("menu-open");
                    });
                });
            }
        });
    </script>
</body>
</html>