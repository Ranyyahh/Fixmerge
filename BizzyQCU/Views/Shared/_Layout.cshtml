<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BizzyQCU</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/Content/layout.css">
    <link rel="stylesheet" href="~/Content/home_about_product_ent.css">
    <link rel="stylesheet" href="~/Content/Chatroom.css">
    <link rel="stylesheet" href="~/Content/MobileNavbar.css">
    @RenderSection("Styles", required: false)
</head>
<body>
    @{
        var isLoggedIn = Session["UserId"] != null;
        var sessionRole = Session["Role"] == null ? string.Empty : Session["Role"].ToString();

        // Account URL based on role
        var accountUrl = "";
        if (sessionRole == "enterprise")
        {
            accountUrl = Url.Action("Index", "Profile");
        }
        else if (sessionRole == "student")
        {
            accountUrl = Url.Action("UserProfile", "Profile");
        }
        else if (sessionRole == "admin")
        {
            accountUrl = Url.Action("LandingAdmin", "AdminPanel");
        }
        else
        {
            accountUrl = Url.Action("Login", "Home");
        }

        // Home URL based on role
        var homeUrl = "";
        if (sessionRole == "enterprise")
        {
            homeUrl = Url.Action("EnterpriseDashboard", "EnterpriseDashboard");
        }
        else if (sessionRole == "student")
        {
            homeUrl = Url.Action("ProductList", "ProductList");
        }
        else if (sessionRole == "admin")
        {
            homeUrl = Url.Action("LandingAdmin", "AdminPanel");
        }
        else
        {
            homeUrl = Url.Action("Homepage", "Home");
        }
    }

    <div class="navbar">

        <a href="javascript:history.back()" class="mobile-back-btn">
            <img src="~/Content/Images/back-btn.png" class="back-icon" alt="Back" />
        </a>

        <div class="logo">
            <a href="@homeUrl"><img src="~/Images/Logo.png" alt="logo" /></a>
        </div>

        <div class="divider"></div>

        <div class="nav-links" id="mainNav">
            @if (sessionRole == "enterprise")
            {
                <a href="@Url.Action("EnterpriseDashboard", "EnterpriseDashboard")">DASHBOARD</a>
                <a href="@Url.Action("AddProduct", "AddProduct")">ADD PRODUCT</a>
                <a href="@Url.Action("ManageOrders", "ManageOrders")">MANAGE ORDERS</a>
                <a href="@Url.Action("EditStore", "EditStore")">EDIT STORE</a>
            }
            else if (sessionRole == "student")
            {
                <a href="@Url.Action("ProductList", "ProductList")">PRODUCTS</a>
                <a href="@Url.Action("EnterpriseList", "EnterpriseList")">ENTERPRISES</a>
                <a href="@Url.Action("History", "Tracking")">TRACK ORDER</a>
                <a href="@Url.Action("About", "Home")">ABOUT US</a>
            }
            else if (sessionRole == "admin")
            {
                <a href="@Url.Action("LandingAdmin", "AdminPanel")">DASHBOARD</a>
                <a href="@Url.Action("AdminUsers", "AdminPanel")">MANAGE USERS</a>
                <a href="@Url.Action("AdminlandingEntrep", "AdminPanel")">ENTERPRISES</a>
            }
            else
            {
                <a href="@Url.Action("Homepage", "Home")">HOME</a>
                <a href="@Url.Action("ProductList", "ProductList")">PRODUCTS</a>
                <a href="@Url.Action("EnterpriseList", "EnterpriseList")">ENTERPRISES</a>
                <a href="@Url.Action("About", "Home")">ABOUT US</a>
            }

            @if (isLoggedIn)
            {
                <a href="@accountUrl" class="account-mobile">ACCOUNT</a>
            }
        </div>

        <div class="right-icons">
            @if (isLoggedIn && sessionRole == "student")
            {
                <div class="cart-icon" style="position:relative;">
                    <img src="~/Images/cart-icon.png" alt="Cart"
                         id="cartIconBtn"
                         style="cursor:pointer;"
                         onclick="handleCartClick()" />
                    <span id="cartBadge"
                          style="display:none; position:absolute; top:-6px; right:-6px;
                                 background:#e03131; color:white; border-radius:50%;
                                 width:18px; height:18px; font-size:11px; font-weight:800;
                                 line-height:18px; text-align:center;">
                    </span>
                </div>

                <div id="cartEmptyToast"
                     style="display:none; position:fixed; top:72px; right:16px; z-index:9999;
                            background:#111FA2; color:white; padding:12px 20px;
                            border-radius:12px; font-weight:700; font-size:0.9rem;
                            box-shadow:0 6px 24px rgba(0,0,0,0.18); pointer-events:none;">
                    &#128722; Please select a product first!
                </div>
            }

            @if (isLoggedIn)
            {
                <div class="account-icon account-desktop">
                    <a href="@accountUrl">
                        <img src="~/Images/account-icon.png" alt="Account" />
                    </a>
                </div>
            }

            <button class="hamburger" id="hamburgerBtn">&#9776;</button>
        </div>

    </div>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align:center; margin-top:2rem; padding:1rem; color:#6c757d;">
        &copy; 2025 BizzyQCU - One Enterprise at a Time
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <script>
        // ── Hamburger ──────────────────────────────────────────────────
        document.addEventListener("DOMContentLoaded", function () {
            var btn = document.getElementById("hamburgerBtn");
            var nav = document.getElementById("mainNav");
            var body = document.body;

            if (btn && nav) {
                btn.addEventListener("click", function () {
                    nav.classList.toggle("open");
                    body.classList.toggle("menu-open", nav.classList.contains("open"));
                });

                nav.querySelectorAll("a").forEach(function (link) {
                    link.addEventListener("click", function () {
                        nav.classList.remove("open");
                        body.classList.remove("menu-open");
                    });
                });
            }

            // ── Cart badge count ────────────────────────────────────────
            updateCartBadge();
            window.addEventListener('storage', function (event) {
                if (event.key === 'bizzyCart') {
                    updateCartBadge();
                }
            });
            window.addEventListener('bizzyCartUpdated', updateCartBadge);
        });

        function getCartCount() {
            var stored = sessionStorage.getItem('bizzyCart');
            if (!stored) { return 0; }
            try {
                var cart = JSON.parse(stored);
                var total = 0;
                for (var i = 0; i < cart.length; i++) {
                    total += cart[i].Quantity || 1;
                }
                return total;
            } catch (e) { return 0; }
        }

        function updateCartBadge() {
            var badge = document.getElementById('cartBadge');
            if (!badge) { return; }
            var count = getCartCount();
            if (count > 0) {
                badge.textContent = count > 9 ? '9+' : count;
                badge.style.display = 'inline-block';
            } else {
                badge.style.display = 'none';
            }
        }

        function notifyCartUpdated() {
            updateCartBadge();
            window.dispatchEvent(new Event('bizzyCartUpdated'));
        }

        function handleCartClick() {
            var count = getCartCount();
            if (count > 0) {
                window.location.href = '@Url.Action("Checkout", "Checkout")';
            } else {
                var toast = document.getElementById('cartEmptyToast');
                if (!toast) { return; }
                toast.style.display = 'block';
                setTimeout(function () {
                    toast.style.display = 'none';
                }, 2500);
            }
        }
    </script>
</body>
</html>
