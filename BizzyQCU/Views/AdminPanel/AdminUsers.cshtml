@{
    Layout = null;
    ViewBag.Title = "BizzyQCU – User Approval";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="~/Content/AdminUsers.css" />
    <link rel="stylesheet" href="~/Content/Fonts/Fonts.css" />
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="@Url.Action("LandingAdmin", "AdminPanel")" class="back-btn" title="Back">&#8592;</a>

            <div class="nav-logo">
                <div class="logo-icon"></div>
            </div>
        </div>

        <div class="search-wrap">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search Name" autocomplete="off" />

                <span class="search-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </span>
            </div>
        </div>

        <div style="width:120px;"></div>
    </header>

    <div class="page-wrapper">
        <div class="table-card">

            <div class="tabs">
                <button class="tab active" id="tabUsers">User Approval</button>
                <button class="tab" id="tabEnterprises">Enterprise Approval</button>
                <button class="tab" id="tabFeedbacks">Feedbacks</button>
            </div>

            <div class="feedback-filter-wrap hidden" id="feedbackFilterWrap">
                <label for="ratingFilter">Filter by Rating:</label>
                <select id="ratingFilter">
                    <option value="">All Ratings</option>
                    <option value="5">5 Stars</option>
                    <option value="4">4 Stars</option>
                    <option value="3">3 Stars</option>
                    <option value="2">2 Stars</option>
                    <option value="1">1 Star</option>
                </select>
                <label for="categoryFilter">Filter by Category:</label>
                <select id="categoryFilter">
                    <option value="">All Categories</option>
                </select>
            </div>

            <div class="tab-panel" id="panelUsers">
                <table class="approval-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Section</th>
                            <th>Student No.</th>
                            <th>QCU ID</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <tr>
                            <td colspan="7" style="text-align:center;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="tab-panel hidden" id="panelEnterprises">
                <table class="approval-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Business Type</th>
                            <th>Contact No.</th>
                            <th>Document</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="enterprisesTableBody">
                        <tr>
                            <td colspan="7" style="text-align:center;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="tab-panel hidden" id="panelFeedbacks">
                <table class="approval-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Contact No.</th>
                            <th>Category</th>
                            <th>Message</th>
                            <th>Rating</th>
                        </tr>
                    </thead>
                    <tbody id="feedbacksTableBody">
                        <tr>
                            <td colspan="5" style="text-align:center;">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <div id="qcuIdModal" class="qcu-id-modal hidden" aria-hidden="true">
        <div class="qcu-id-modal-backdrop" onclick="closeQcuIdModal()"></div>
        <div class="qcu-id-modal-content" role="dialog" aria-modal="true" aria-label="QCU ID Preview">
            <button type="button" class="qcu-id-modal-close" onclick="closeQcuIdModal()" aria-label="Close">&times;</button>
            <h3 id="previewModalTitle">Preview</h3>
            <img id="qcuIdPreviewImage" alt="QCU ID" />
        </div>
    </div>

    <div id="editRequestModal" class="qcu-id-modal hidden" aria-hidden="true">
        <div class="qcu-id-modal-backdrop" onclick="closeEditModal()"></div>
        <div class="qcu-id-modal-content edit-modal-content" role="dialog" aria-modal="true" aria-label="Edit Request">
            <button type="button" class="qcu-id-modal-close" onclick="closeEditModal()" aria-label="Close">&times;</button>
            <h3 id="editModalTitle">Edit Request</h3>
            <form id="editRequestForm" onsubmit="submitEditForm(event)"></form>
        </div>
    </div>

    <div id="saveConfirmModal" class="qcu-id-modal hidden" aria-hidden="true">
        <div class="qcu-id-modal-backdrop" onclick="closeSaveConfirmModal()"></div>
        <div class="qcu-id-modal-content confirm-modal-content" role="dialog" aria-modal="true" aria-label="Confirm Save Changes">
            <button type="button" class="qcu-id-modal-close" onclick="closeSaveConfirmModal()" aria-label="Close">&times;</button>
            <h3>Confirm Changes</h3>
            <p class="confirm-text">Are you sure you want to save these changes?</p>
            <div class="edit-form-actions">
                <button type="button" class="edit-cancel-btn" onclick="closeSaveConfirmModal()">Cancel</button>
                <button type="button" class="edit-save-btn" onclick="confirmAndSaveChanges()">Yes, Save</button>
            </div>
        </div>
    </div>

    <div id="deleteFeedbackConfirmModal" class="qcu-id-modal hidden" aria-hidden="true">
        <div class="qcu-id-modal-backdrop" onclick="closeDeleteFeedbackConfirmModal()"></div>
        <div class="qcu-id-modal-content confirm-modal-content" role="dialog" aria-modal="true" aria-label="Confirm Delete Feedback">
            <button type="button" class="qcu-id-modal-close" onclick="closeDeleteFeedbackConfirmModal()" aria-label="Close">&times;</button>
            <h3>Delete Feedback</h3>
            <p class="confirm-text">Are you sure you want to delete this feedback?</p>
            <div class="edit-form-actions">
                <button type="button" class="edit-cancel-btn" onclick="closeDeleteFeedbackConfirmModal()">Cancel</button>
                <button type="button" class="delete-btn" onclick="confirmDeleteFeedback()">Delete</button>
            </div>
        </div>
    </div>

    <script src="~/Scripts/AdminUser.js?v=20260508f"></script>
</body>
</html>
