@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Edit Product - BizzyQCU";
}

@section Styles {
    <link rel="stylesheet" href="~/Content/EnterpriseDashboard.css">
}

<div class="add-product-page">
    <div class="add-product-shell">
        <h2 style="margin-bottom: 20px; color: #0f1a52;">Edit Product</h2>

        <div class="add-product-grid">
            <div class="add-product-left">
                <label for="productImage" class="add-product-image-box" title="Upload Product Image">
                    <input id="productImage" type="file" accept="image/*" class="add-product-image-input" />
                    <span class="add-product-image-icon">📷</span>
                    <img id="imagePreview" class="product-image-preview" style="display: none;" />
                </label>
                @if (ViewBag.Product.HasImage)
                {
                    <div style="text-align: center; margin-top: 10px;">
                        <small>Current image loaded. Upload new to replace.</small>
                    </div>
                }

                <div class="add-product-actions">
                    <button type="button" class="add-product-btn add-product-btn-save" id="updateProductBtn">Update Product</button>
                    <button type="button" class="add-product-btn add-product-btn-cancel" onclick="window.location.href='/EditStore/EditStore'">Cancel</button>
                </div>
            </div>

            <div class="add-product-form">
                <input type="hidden" id="productId" value="@ViewBag.Product.ProductId" />
                <input type="text" id="productName" placeholder="Product Name" value="@ViewBag.Product.ProductName" />
                <input type="number" step="0.01" min="0" id="productPrice" placeholder="Price" value="@ViewBag.Product.Price" />
                <select id="productCategory">
                    <option value="">Select Category</option>
                    <option value="Food" @(ViewBag.CategoryName == "Food" ? "selected" : "")>Food</option>
                    <option value="Drinks" @(ViewBag.CategoryName == "Drinks" ? "selected" : "")>Drinks</option>
                    <option value="Merch" @(ViewBag.CategoryName == "Merch" ? "selected" : "")>Merch</option>
                </select>
                <input type="text" id="preparationTime" placeholder="Preparation Time (e.g., 15-20 mins)" value="@(ViewBag.Product.PreparationTime > 0 ? ViewBag.Product.PreparationTime + " mins" : "")" />
                <textarea id="productDescription" placeholder="Description">@ViewBag.Product.Description</textarea>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/EditProduct.js"></script>
}