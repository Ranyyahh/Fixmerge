@model BizzyQCU.Controllers.EnterpriseDashboardViewModel
@{
    ViewBag.Title = "Enterprise Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/Content/EnterpriseInfo.css" />
<style>
    .logout-confirm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .logout-confirm-overlay.show {
        display: flex;
    }

    .logout-confirm-card {
        width: min(92vw, 420px);
        background: #fff;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
    }

    .logout-confirm-card h3 {
        margin: 0 0 8px;
        color: #1e2f98;
    }

    .logout-confirm-card p {
        margin: 0;
        color: #555;
    }

    .logout-confirm-actions {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .logout-confirm-actions button {
        border: none;
        border-radius: 8px;
        padding: 8px 14px;
        cursor: pointer;
        font-weight: 600;
    }

    .logout-cancel-btn {
        background: #eceefc;
        color: #2d3cb3;
    }

    .logout-proceed-btn {
        background: #f0c330;
        color: #2b2b2b;
    }
</style>

<section class="screen screen-dashboard">
    <div class="dashboard-panel">
        <!-- Left: Enterprise Card -->
        <div class="info-card enterprise-card">
            <div class="panel-heading">
                <span class="panel-heading-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 8h18v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8z" />
                        <path d="M9 8V6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" />
                    </svg>
                </span>
                <h1>Enterprise Information</h1>
            </div>
            <div class="panel-divider"></div>

            <div class="enterprise-card-body">
                <div class="avatar-shell">
                    <img class="avatar-image" src="@Model.Enterprise.PhotoDataUrl" alt="Enterprise profile photo" />
                </div>

                <dl class="details-grid">
                    <div class="details-row">
                        <dt>Enterprise Name</dt>
                        <dd>@Model.Enterprise.Name</dd>
                    </div>
                    <div class="details-row">
                        <dt>Type</dt>
                        <dd>@Model.Enterprise.Type</dd>
                    </div>
                    <div class="details-row">
                        <dt>Gcash</dt>
                        <dd>@Model.Enterprise.Gcash</dd>
                    </div>
                    <div class="details-row">
                        <dt>Role</dt>
                        <dd>@Model.Enterprise.Role</dd>
                    </div>
                </dl>

                <div class="enterprise-side-tools">
                    <div class="qr-display-card">
                        <span class="qr-display-label">Enterprise QR</span>
                        <div class="qr-display-frame">
                            @if (!string.IsNullOrWhiteSpace(Model.Enterprise.QrDataUrl))
                            {
                                <img class="qr-display-image" src="@Model.Enterprise.QrDataUrl" alt="Enterprise QR code" />
                            }
                            else
                            {
                                <span class="qr-display-placeholder">No QR uploaded</span>
                            }
                        </div>
                    </div>

                    <a class="outline-action-button dashboard-edit-button" href="@Url.Action("EnterpriseProfile", "Profile")">
                        <span class="button-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M3 17.2V21h3.8L18.4 9.4l-3.8-3.8z" />
                                <path d="M14.6 5.6 17.8 2.4a2.1 2.1 0 0 1 3 3l-3.2 3.2" />
                            </svg>
                        </span>
                        Edit
                    </a>
                </div>
            </div>
        </div>

        <!-- Right Side Grid -->
        <div class="dashboard-grid">
            <!-- Manager Card -->
            <div class="info-card manager-card">
                <h2 class="section-title section-title-blue">Enterprise Manager</h2>
                <div class="panel-divider"></div>

                <dl class="details-grid compact">
                    <div class="details-row">
                        <dt>Name</dt>
                        <dd>@Model.Manager.Name</dd>
                    </div>
                    <div class="details-row">
                        <dt>Section</dt>
                        <dd>@Model.Manager.Section</dd>
                    </div>
                    <div class="details-row">
                        <dt>Student ID</dt>
                        <dd>@Model.Manager.StudentId</dd>
                    </div>
                </dl>

                <div class="panel-divider bottom-divider"></div>
            </div>

            <!-- Stats Card -->
            <div class="info-card stats-card">
                <div class="panel-heading stats-heading">
                    <span class="panel-heading-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 20V9" />
                            <path d="M10 20V4" />
                            <path d="M16 20v-7" />
                            <path d="M22 20V2" />
                        </svg>
                    </span>
                    <h2>Enterprise Stats</h2>
                </div>
                <div class="panel-divider"></div>

                <div class="stats-list">
                    <div class="stats-row">
                        <span class="stats-icon">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="9" />
                                <path d="m8.5 12.2 2.1 2.2 4.9-5.1" />
                            </svg>
                        </span>
                        <span class="stats-label">Orders Completed</span>
                        <strong class="stats-value">@Model.Stats.OrdersCompleted</strong>
                    </div>

                    <div class="stats-row">
                        <span class="stats-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="m12 3 9 4.5v9L12 21 3 16.5v-9z" />
                                <path d="m3 7.5 9 4.5 9-4.5" />
                                <path d="M12 12v9" />
                            </svg>
                        </span>
                        <span class="stats-label">Products Listed</span>
                        <strong class="stats-value">@Model.Stats.ProductsListed</strong>
                    </div>
                </div>

                <div class="panel-divider"></div>

                <div class="sales-row">
                    <span class="stats-icon stats-icon-dark">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 3c-3.3 0-6 2.2-6 5 0 1.9 1.2 3 2.3 4 .9.8 1.7 1.6 1.7 2.8V16H8.8A1.8 1.8 0 0 0 7 17.8v.2C7 20.8 9.2 23 12 23s5-2.2 5-5v-.2A1.8 1.8 0 0 0 15.2 16H14v-1.2c0-1.2.8-2 1.7-2.8 1.1-1 2.3-2.1 2.3-4 0-2.8-2.7-5-6-5z" />
                            <path d="M10.5 8.3c.3-.7.9-1.1 1.7-1.1.8 0 1.3.4 1.3 1 0 .6-.3.9-1.4 1.3-1.4.5-2 .9-2.2 2h1.2c.2-.5.5-.7 1.3-1 .9-.3 2.2-.9 2.2-2.4 0-1.4-1.1-2.3-2.7-2.3-1.5 0-2.7.8-3.1 2.5z" />
                        </svg>
                    </span>
                    <span class="stats-label">Total Sales</span>
                    <strong class="sales-value">P @Model.Stats.TotalSales.ToString("N2")</strong>
                </div>

                <div class="stats-actions">
                    <a class="outline-action-button compact-button" href="@Url.Action("Transactions", "Profile")">
                        Transaction History
                    </a>
                </div>
            </div>
        </div>
    </div>

    <form action="@Url.Action("Logout", "Account")" method="post" class="logout-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="logout-button">
            <span class="button-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M10 5H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h5" />
                    <path d="M14 16l4-4-4-4" />
                    <path d="M8 12h10" />
                </svg>
            </span>
            Log Out
        </button>
    </form>
</section>

<div id="logoutConfirmModal" class="logout-confirm-overlay" aria-hidden="true">
    <div class="logout-confirm-card" role="dialog" aria-modal="true" aria-labelledby="logoutConfirmTitle">
        <h3 id="logoutConfirmTitle">Log Out</h3>
        <p>Are you sure you want to log out?</p>
        <div class="logout-confirm-actions">
            <button id="logoutCancelBtn" type="button" class="logout-cancel-btn">Cancel</button>
            <button id="logoutConfirmBtn" type="button" class="logout-proceed-btn">Log Out</button>
        </div>
    </div>
</div>

<script>
    (function () {
        var logoutForm = document.querySelector(".logout-form");
        var logoutModal = document.getElementById("logoutConfirmModal");
        var logoutCancelBtn = document.getElementById("logoutCancelBtn");
        var logoutConfirmBtn = document.getElementById("logoutConfirmBtn");
        var allowSubmit = false;

        if (!logoutForm) return;

        logoutForm.addEventListener("submit", function (event) {
            if (allowSubmit) return;
            event.preventDefault();
            logoutModal.classList.add("show");
            logoutModal.setAttribute("aria-hidden", "false");
        });

        logoutCancelBtn.addEventListener("click", function () {
            logoutModal.classList.remove("show");
            logoutModal.setAttribute("aria-hidden", "true");
        });

        logoutConfirmBtn.addEventListener("click", function () {
            allowSubmit = true;
            logoutForm.submit();
        });

        logoutModal.addEventListener("click", function (event) {
            if (event.target === logoutModal) {
                logoutModal.classList.remove("show");
                logoutModal.setAttribute("aria-hidden", "true");
            }
        });
    })();
</script>
