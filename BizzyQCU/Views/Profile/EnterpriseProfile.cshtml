@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model BizzyQCU.Controllers.AccountSettingsPageViewModel
@{
    var showProfileSaveActions = ViewBag.ShowProfileSaveActions == null || (bool)ViewBag.ShowProfileSaveActions;
    var showProfileEditTools = ViewBag.ShowProfileEditTools == true;
}

<link rel="stylesheet" href="~/Content/EnterpriseProfile.css" />

@using (Html.BeginForm("SaveEnterpriseProfile", "Profile", FormMethod.Post, new { enctype = "multipart/form-data", id = "enterpriseProfileForm" }))
{
    @Html.AntiForgeryToken()
    if (TempData["FlashMessage"] != null)
    {
        <div style="max-width:1140px;margin:14px auto 0;padding:10px 14px;border-radius:8px;background:#eef7ff;color:#0b3a75;font-weight:600;">
            @TempData["FlashMessage"]
        </div>
    }
    <div class="enterprise-container">
        <div class="header">
            <h1>Enterprise Information</h1>
        </div>

        <div class="content">
            <!-- Two Columns: Enterprise Info + Manager Info -->
            <div class="two-columns">
                <!-- LEFT CARD: Enterprise Information -->
                <div class="info-card">
                    <div class="card-title">Enterprise Information</div>

                    <!-- Profile Picture -->
                    <div class="profile-pic-area">
                        <div class="profile-pic" onclick="document.getElementById('profileUpload').click()">
                            @if (!string.IsNullOrWhiteSpace(Model.Profile.PhotoDataUrl))
                            {
                                <img src="@Model.Profile.PhotoDataUrl" alt="Profile" style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                <span>??</span>
                            }
                        </div>
                        <input type="file" id="profileUpload" name="profileFile" accept="image/*" style="display: none;" />
                        <button type="button" class="change-photo-btn" onclick="document.getElementById('profileUpload').click()">Change Photo</button>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Enterprise Name</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.EnterpriseName, new { @class = "editable-field" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Enterprise Type</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.EnterpriseType, new { @class = "editable-field" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Gcash No.</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.Contact, new { @class = "editable-field js-gcash-number", inputmode = "numeric", maxlength = "11", pattern = "09[0-9]{9}", title = "Enter an 11-digit Gcash number starting with 09." })
                            @Html.ValidationMessageFor(m => m.Profile.Contact, "", new { @class = "field-validation-error" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Email</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.Email, new { @class = "editable-field", type = "email" })
                        </div>
                    </div>
                </div> <!-- END OF LEFT CARD -->
                <!-- RIGHT CARD: Enterprise Manager Information + QR Section -->
                <div class="info-card">
                    <div class="card-title">Enterprise Manager Information</div>

                    <div class="info-row">
                        <div class="info-label">Manager Name</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.ManagerName, new { @class = "editable-field" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Student ID</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.StudentId, new { @class = "editable-field js-student-id", maxlength = "7", pattern = "[0-9]{2}-[0-9]{4}", title = "Use the format 00-0000." })
                            @Html.ValidationMessageFor(m => m.Profile.StudentId, "", new { @class = "field-validation-error" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Section</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.Section, new { @class = "editable-field" })
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Manager Gcash No.</div>
                        <div class="info-value">
                            @Html.TextBoxFor(m => m.Profile.ManagerContactNumber, new { @class = "editable-field js-gcash-number", inputmode = "numeric", maxlength = "11", pattern = "09[0-9]{9}", title = "Enter an 11-digit Gcash number starting with 09." })
                            @Html.ValidationMessageFor(m => m.Profile.ManagerContactNumber, "", new { @class = "field-validation-error" })
                        </div>
                    </div>

                    <!-- QR SECTION - NASA LOOB NG RIGHT CARD -->
                    <div class="qr-bottom-section">
                        <div class="qr-left">
                            <h3>Gcash QR</h3>
                            <p>Scan to pay</p>
                        </div>
                        <div class="qr-code-box">
                            @if (!string.IsNullOrWhiteSpace(Model.Profile.QrDataUrl))
                            {
                                <img id="qrPreview" src="@Model.Profile.QrDataUrl" alt="QR Code" />
                            }
                            else
                            {
                                <span>No QR</span>
                            }
                        </div>
                    </div>

                    <!-- Upload QR and Edit Info Buttons -->
                    <div class="upload-qr-area">
                        <button type="button" class="upload-qr-btn" onclick="document.getElementById('qrUpload').click()">?? Upload QR</button>
                        <input type="file" id="qrUpload" name="qrFile" accept="image/*" style="display: none;" />
                    </div>
                </div> <!-- END OF RIGHT CARD -->
            </div> <!-- END OF TWO COLUMNS -->
            <!-- Action Buttons - NASA PINAKABABA -->
            @if (showProfileSaveActions)
            {
                <div class="actions-row">
                    <button class="btn-save" type="submit">Save</button>
                    <button class="btn-password" type="button" data-bs-toggle="modal" data-bs-target="#passwordModal">Change Password</button>
                </div>
            }
        </div>
    </div>
}

<script>
    function normalizeDigits(value, maxLength) {
        return (value || '').replace(/\D/g, '').slice(0, maxLength);
    }

    document.querySelectorAll('.js-gcash-number').forEach(function (input) {
        input.addEventListener('input', function () {
            this.value = normalizeDigits(this.value, 11);
        });
    });

    document.querySelectorAll('.js-student-id').forEach(function (input) {
        input.addEventListener('input', function () {
            const digits = normalizeDigits(this.value, 6);
            this.value = digits.length > 2 ? digits.slice(0, 2) + '-' + digits.slice(2) : digits;
        });
    });

    document.getElementById('enterpriseProfileForm')?.addEventListener('submit', function (event) {
        const gcashPattern = /^09\d{9}$/;
        const studentIdPattern = /^\d{2}-\d{4}$/;
        const gcashInput = document.querySelector('[name="Profile.Contact"]');
        const managerGcashInput = document.querySelector('[name="Profile.ManagerContactNumber"]');
        const studentIdInput = document.querySelector('[name="Profile.StudentId"]');

        if (gcashInput && !gcashPattern.test(gcashInput.value.trim())) {
            event.preventDefault();
            alert('Gcash No. must be 11 digits and start with 09.');
            gcashInput.focus();
            return;
        }

        if (managerGcashInput && managerGcashInput.value.trim() && !gcashPattern.test(managerGcashInput.value.trim())) {
            event.preventDefault();
            alert('Manager Gcash No. must be 11 digits and start with 09.');
            managerGcashInput.focus();
            return;
        }

        if (studentIdInput && studentIdInput.value.trim() && !studentIdPattern.test(studentIdInput.value.trim())) {
            event.preventDefault();
            alert('Student ID must use the format 00-0000.');
            studentIdInput.focus();
        }
    });

    // Profile picture preview
    document.getElementById('profileUpload')?.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const profilePic = document.querySelector('.profile-pic');
                profilePic.innerHTML = `<img src="${event.target.result}" alt="Profile" style="width:100%;height:100%;object-fit:cover;" />`;
            };
            reader.readAsDataURL(file);
        }
    });

    // QR preview
    document.getElementById('qrUpload')?.addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const qrBox = document.querySelector('.qr-code-box');
                qrBox.innerHTML = `<img src="${event.target.result}" alt="QR" style="width:80px;height:80px;object-fit:contain;" />`;
            };
            reader.readAsDataURL(file);
        }
    });
</script>
