@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .auth-bg {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding-top: 100px;
        padding-bottom: 40px;
        box-sizing: border-box;
    }

    .login-card {
        width: 380px;
        padding: 35px 32px;
        background: white;
        border-radius: 28px;
        text-align: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

        .login-card h2 {
            color: #1a2a6f;
            font-size: 26px;
            margin-bottom: 25px;
            font-weight: 700;
        }

        .login-card input {
            width: 100%;
            padding: 12px 18px;
            margin: 8px 0;
            border-radius: 50px;
            border: 1.5px solid #e8ecef;
            background: #fefefe;
            box-sizing: border-box;
            font-size: 14px;
        }

            .login-card input:focus {
                outline: none;
                border-color: #f5a623;
                box-shadow: 0 0 0 3px rgba(245,166,35,0.15);
            }

    .auth-btn {
        width: 100%;
        padding: 12px;
        background: #f5a623;
        border: none;
        border-radius: 50px;
        font-weight: 800;
        font-size: 15px;
        color: #1a2a6f;
        margin-top: 20px;
        cursor: pointer;
        transition: all 0.3s;
    }

        .auth-btn:hover {
            background: #e09612;
            transform: translateY(-2px);
        }

    .auth-links {
        margin-top: 20px;
        font-size: 13px;
    }

        .auth-links a {
            color: #1a2a6f;
            text-decoration: none;
            font-weight: 600;
        }

            .auth-links a:hover {
                text-decoration: underline;
                color: #f5a623;
            }

    .message {
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 20px;
        text-align: center;
        font-size: 13px;
        display: none;
    }

    @@media (max-width: 768px) {
        .login-card {
            width: 90%;
            max-width: 350px;
            padding: 25px 20px;
        }

            .login-card h2 {
                font-size: 22px;
            }

            .login-card input {
                padding: 10px 15px;
                font-size: 13px;
            }

        .auth-btn {
            padding: 10px;
            font-size: 14px;
        }
    }
</style>

<div class="auth-bg">
    <div class="login-card">
        <h2>LOGIN</h2>
        <div id="messageBox" class="message"></div>
        <form onsubmit="return loginUser(event)">
            <input type="text" id="username" placeholder="Username" required>
            <input type="password" id="password" placeholder="Password" required>
            <button type="submit" class="auth-btn">LOGIN</button>
        </form>
        <div class="auth-links">
            New to BizzyQCU? <a href="@Url.Action("RegisterStudent", "Home")">Sign up</a>
        </div>
    </div>
</div>

<script>
    function showMessage(message, type) {
        var msgBox = document.getElementById('messageBox');
        msgBox.textContent = message;
        msgBox.style.backgroundColor = type === 'error' ? '#fee' : '#e8f5e9';
        msgBox.style.color = type === 'error' ? '#c33' : '#2e7d32';
        msgBox.style.display = 'block';
        setTimeout(function () { msgBox.style.display = 'none'; }, 3000);
    }
    function loginUser(event) {
        event.preventDefault();
        var users = JSON.parse(localStorage.getItem('bizzyqcu_users') || '[]');
        var username = document.getElementById('username').value;
        var password = document.getElementById('password').value;
        var user = null;
        for (var i = 0; i < users.length; i++) {
            if (users[i].username === username && users[i].password === password) {
                user = users[i];
                break;
            }
        }
        if (user) {
            sessionStorage.setItem('currentUser', JSON.stringify(user));
            var displayName = user.firstName || user.enterpriseName || user.username;
            showMessage('Welcome ' + displayName + '! Login successful.', 'success');
            setTimeout(function () {
                alert('Logged in as: ' + displayName + '\nUser Type: ' + (user.userType === 'student' ? 'Student' : 'Enterprise'));
                document.getElementById('username').value = '';
                document.getElementById('password').value = '';
            }, 1500);
        } else {
            showMessage('Invalid username or password!', 'error');
        }
        return false;
    }
</script>